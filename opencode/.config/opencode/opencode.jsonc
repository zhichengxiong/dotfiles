{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "cohere-oss/glm-5-2-fp8",
  "provider": {
    "cohere-oss": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cohere OSS",
      "options": {
        "baseURL": "https://api.oss-models-d8hv27.cloud.cohere.com/compatibility/v1/"
      },
      "models": {
        "glm-5-2-fp8": {
          "name": "GLM 5.2 FP8",
          "limit": {
            "context": 300000,
            "output": 16000
          },
          "interleaved": {
            "field": "reasoning_content"
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "limit": {
            "context": 128000,
            "output": 16000
          }
        }
      }
    }
  }
}